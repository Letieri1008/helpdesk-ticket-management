DJANGO_SECRET_KEY=change-me-in-real-environments
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Use sqlite for local demos. Switch to postgres when a PostgreSQL service exists.
DB_ENGINE=sqlite

# PostgreSQL settings used when DB_ENGINE=postgres
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
